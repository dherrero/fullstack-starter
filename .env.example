# Database Configuration
POSTGRESDB_HOST=localhost
POSTGRESDB_PORT=5432
POSTGRESDB_DATABASE=your_db_name
POSTGRESDB_USER=postgres
POSTGRESDB_PASSWORD=password

# Public JWT secrets used by the gateway. Access and refresh tokens are
# signed with separate secrets so the compromise of one does not let an
# attacker forge the other. Replace with strong random values in prod.
JWT_ACCESS_SECRET=dev-access-secret-replace-me
JWT_REFRESH_SECRET=dev-refresh-secret-replace-me
JWT_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=8h

# Internal JWT shared between gateway and downstream services
# (only used inside the docker private network)
INTERNAL_JWT_SECRET=internal-dev-secret-replace-me

# Gateway settings
GATEWAY_PORT=3100
API_BASE_URL=http://api:3200

# API settings
NODE_PORT=3200
NODE_ENV=development
NODE_PRODUCTION=false

# CORS origins allowed by the gateway (comma-separated)
CORS_ORIGIN=http://localhost:4200

# Database Retry Configuration
DB_MAX_RETRIES=10
DB_RETRY_DELAY=5000
DB_MAX_RETRY_DELAY=30000
DB_BACKOFF_MULTIPLIER=1.5
DB_JITTER=true

# Database Pool Configuration
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=10000
DB_POOL_EVICT=1000

# Database Timeout Configuration
DB_CONNECT_TIMEOUT=60000
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000
HASH_SALT_ROUNDS=10
